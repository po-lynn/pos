<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_inherit_skb" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.skb.pos.receipt</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='auto_printing']" position="after">
                <setting id="skb_receipt_settings" string="SKB Receipt">
                    <div class="content-group">
                        <div class="row mt-4">
                            <label for="skb_opening_time" class="col-lg-4 o_light_label" string="Opening Time" />
                            <field name="skb_opening_time" class="col-lg-8" placeholder="e.g. 8:00 A.M." />
                        </div>
                        <div class="row mt-2">
                            <label for="skb_closing_time" class="col-lg-4 o_light_label" string="Closing Time" />
                            <field name="skb_closing_time" class="col-lg-8" placeholder="e.g. 7:30 P.M." />
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>

</odoo>
