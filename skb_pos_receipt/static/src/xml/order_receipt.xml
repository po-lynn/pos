<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="skb_pos_receipt.OrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-receipt p-2')]" position="replace">
            <div class="pos-receipt p-2" style="font-family: Arial; font-size: 11px;">

                <!-- Header: passes slip_no, date, customer, cashier name into ReceiptHeader -->
                <ReceiptHeader data="{
                    ...props.data.headerData,
                    slip_no: props.data.headerData.trackingNumber || props.data.name,
                    skb_date: props.data.date,
                    skb_customer: props.data.skb_customer,
                    skb_cashier_name: props.data.headerData.skb_cashier_name
                }" />

                <!-- Line items table -->
                <table width="100%" style="font-size: 11px; border-collapse: collapse; margin-top: 2px;">
                    <thead>
                        <tr style="border-top: 2px solid #000; border-bottom: 2px solid #000;">
                            <th style="width: 6%;  text-align: center; padding: 3px;">No</th>
                            <th style="width: 40%; text-align: left;   padding: 3px;">Description</th>
                            <th style="width: 10%; text-align: center; padding: 3px;">Qty</th>
                            <th style="width: 12%; text-align: center; padding: 3px;">Unit</th>
                            <th style="width: 14%; text-align: right;  padding: 3px;">Price</th>
                            <th style="width: 18%; text-align: right;  padding: 3px;">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="i" t-value="0" />
                        <t t-foreach="props.data.orderlines" t-as="line" t-key="line_index">
                            <t t-if="!line.skb_is_discount">
                                <t t-set="i" t-value="i + 1" />
                            </t>
                            <tr t-attf-class="{{ line.skb_is_discount ? 'skb-discount-line' : '' }}">
                                <td style="text-align: center; padding: 2px 3px;"><t t-if="!line.skb_is_discount" t-esc="i" /></td>
                                <td style="text-align: left;   padding: 2px 3px;"><t t-esc="line.productName" /></td>
                                <td style="text-align: center; padding: 2px 3px;"><t t-esc="line.skb_qty or line.qty" /></td>
                                <td style="text-align: center; padding: 2px 3px;"><t t-esc="line.unit" /></td>
                                <td style="text-align: right;  padding: 2px 3px;"><t t-esc="line.unitPrice" /></td>
                                <td style="text-align: right;  padding: 2px 3px;"><t t-esc="line.price" /></td>
                            </tr>
                        </t>

                        <!-- Divider before totals -->
                        <tr>
                            <td colspan="6" style="border-top: 2px solid #000; padding: 0;"></td>
                        </tr>

                        <!-- Net Total (sum of positive lines) -->
                        <tr>
                            <td colspan="4" style="text-align: right; padding: 2px 3px; font-weight: bold;">Net Total</td>
                            <td colspan="2" style="text-align: right; padding: 2px 3px; font-weight: bold;">
                                <t t-esc="props.formatCurrency(props.data.skb_net_total)" />
                            </td>
                        </tr>

                        <!-- Discount deduction (hidden when 0) -->
                        <t t-if="props.data.skb_discount_amount">
                            <tr>
                                <td colspan="4" style="text-align: right; padding: 2px 3px;">Discount</td>
                                <td colspan="2" style="text-align: right; padding: 2px 3px;">
                                    -<t t-esc="props.formatCurrency(props.data.skb_discount_amount)" />
                                </td>
                            </tr>
                        </t>

                        <!-- Total = Net Total - Discount -->
                        <tr>
                            <td colspan="4" style="text-align: right; padding: 2px 3px; font-weight: bold;">Total</td>
                            <td colspan="2" style="text-align: right; padding: 2px 3px; font-weight: bold;">
                                <t t-esc="props.formatCurrency(props.data.skb_total)" />
                            </td>
                        </tr>

                        <!-- Payment lines -->
                        <t t-foreach="props.data.paymentlines" t-as="paymentline" t-key="paymentline_index">
                            <tr>
                                <td colspan="4" style="text-align: right; padding: 2px 3px;">
                                    <t t-esc="paymentline.name" />
                                </td>
                                <td colspan="2" style="text-align: right; padding: 2px 3px;">
                                    <t t-esc="props.formatCurrency(paymentline.amount)" />
                                </td>
                            </tr>
                        </t>

                        <!-- Balance (Change) -->
                        <tr>
                            <td colspan="4" style="text-align: right; padding: 2px 3px; font-weight: bold;">Balance</td>
                            <td colspan="2" style="text-align: right; padding: 2px 3px; font-weight: bold;">
                                <t t-esc="props.formatCurrency(props.data.order_change)" />
                            </td>
                        </tr>

                    </tbody>
                </table>

                <!-- Footer: business hours -->
                <t t-if="props.data.skb_opening_time or props.data.skb_closing_time">
                    <div style="text-align: center; margin-top: 6px; font-size: 11px;">
                        ON : <t t-esc="props.data.skb_opening_time" />,
                        OFF : <t t-esc="props.data.skb_closing_time" />
                    </div>
                </t>

                <!-- Footer: custom text from POS config receipt_footer -->
                <t t-if="props.data.footer">
                    <div class="pos-receipt-center-align"
                         style="white-space: pre-line; text-align: center; font-size: 11px; margin-top: 4px;">
                        <t t-esc="props.data.footer" />
                    </div>
                </t>

            </div>
        </xpath>
    </t>
</templates>
