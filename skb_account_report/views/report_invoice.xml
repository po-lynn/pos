<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_invoice_document_inherit_skb" inherit_id="account.report_invoice_document">

        <!-- Bigger body font for A5 print -->
        <xpath expr="//t[@t-set='forced_vat']" position="after">
            <style>
                .page { font-size: 16px; line-height: 1.35; }
                .page table.o_main_table th, .page table.o_main_table td { font-size: 16px; }
            </style>
        </xpath>

        <!-- Initialize line counter before the foreach loop -->
        <xpath expr="//t[@t-foreach='lines'][@t-as='line']" position="before">
            <t t-set="line_no" t-value="0"/>
        </xpath>

        <!-- Hide the entire row for negative product lines (discount lines) -->
        <xpath expr="//t[@t-foreach='lines'][@t-as='line']/tr" position="attributes">
            <attribute name="t-if">line.display_type != 'product' or line.price_subtotal &gt;= 0</attribute>
        </xpath>

        <!-- Remove Taxes column -->
        <xpath expr="//th[@name='th_taxes']" position="replace"/>
        <xpath expr="//td[@name='td_taxes']" position="replace"/>

        <!-- Remove currency symbol from line item amounts -->
        <xpath expr="//td[@name='td_subtotal']/span" position="attributes">
            <attribute name="t-options">{'widget': 'float', 'precision': 0}</attribute>
        </xpath>

        <!-- Inject Net Total + Discount rows into the totals box before the existing Total row -->
        <xpath expr="//t[@t-call='account.document_tax_totals']" position="before">
            <t t-set="skb_net_total" t-value="sum(l.price_subtotal for l in o.invoice_line_ids if l.display_type == 'product' and l.price_subtotal &gt;= 0)"/>
            <t t-set="skb_disc_total" t-value="sum(-l.price_subtotal for l in o.invoice_line_ids if l.display_type == 'product' and l.price_subtotal &lt; 0)"/>
            <tr class="o_subtotal">
                <td>Net Total</td>
                <td class="text-end">
                    <span t-att-class="oe_subtotal_footer_separator" t-out="skb_net_total"
                          t-options="{'widget': 'float', 'precision': 0}"/>
                </td>
            </tr>
            <t t-if="skb_disc_total &gt; 0">
                <tr>
                    <td>Discount</td>
                    <td class="text-end o_price_total">
                        <span class="text-nowrap">-<t t-out="skb_disc_total"
                               t-options="{'widget': 'float', 'precision': 0}"/></span>
                    </td>
                </tr>
            </t>
        </xpath>

        <!-- Remove currency symbol from payment amounts (Paid on...) -->
        <xpath expr="//t[@t-foreach='payments_vals']//td[@class='text-end']/span" position="attributes">
            <attribute name="t-options">{'widget': 'float', 'precision': 0}</attribute>
        </xpath>

        <!-- Remove currency symbol from Amount Due -->
        <xpath expr="//span[@t-field='o.amount_residual']" position="attributes">
            <attribute name="t-options">{'widget': 'float', 'precision': 0}</attribute>
        </xpath>

        <!-- Add No. header before Description -->
        <xpath expr="//th[@name='th_description']" position="before">
            <th name="th_no" class="text-end pe-2" style="width:32px;"><span>No.</span></th>
        </xpath>

        <!-- Add left padding to Description header -->
        <xpath expr="//th[@name='th_description']" position="attributes">
            <attribute name="style">padding-left: 12px;</attribute>
        </xpath>

        <!-- Split Quantity header into Quantity + Unit, narrow the column -->
        <xpath expr="//th[@name='th_quantity']" position="replace">
            <th name="th_quantity" class="text-end" style="width:60px;"><span>Quantity</span></th>
            <th name="th_uom" class="text-start text-nowrap" groups="uom.group_uom"><span>Unit</span></th>
        </xpath>

        <!-- Add No. cell and increment counter for each product line -->
        <xpath expr="//td[@name='account_invoice_line_name']" position="before">
            <t t-set="line_no" t-value="line_no + 1"/>
            <td name="td_no" class="text-end pe-2">
                <span t-out="line_no"/>
            </td>
        </xpath>

        <!-- Add left padding to Description cell -->
        <xpath expr="//td[@name='account_invoice_line_name']" position="attributes">
            <attribute name="style">padding-left: 12px;</attribute>
        </xpath>

        <!-- Split td_quantity: separate Qty and UoM cells, strip .00 decimals -->
        <xpath expr="//td[@name='td_quantity']" position="replace">
            <td name="td_quantity" class="o_td_quantity text-end" style="width:60px;">
                <span t-field="line.quantity" t-options="{'widget': 'float', 'precision': 0}" class="text-nowrap"/>
            </td>
            <td name="td_uom" class="text-start text-nowrap" groups="uom.group_uom">
                <span t-field="line.product_uom_id"/>
            </td>
        </xpath>

        <!-- Strip .00 decimals from Unit Price -->
        <xpath expr="//td[@name='td_price_unit']/span" position="attributes">
            <attribute name="t-options">{'widget': 'float', 'precision': 0}</attribute>
        </xpath>

    </template>

    <!-- Remove currency symbol from Total row; hide Untaxed Amount when no taxes -->
    <template id="document_tax_totals_inherit_skb" inherit_id="account.document_tax_totals">
        <xpath expr="//tr[@class='o_subtotal']" position="attributes">
            <attribute name="t-if">len(subtotal['tax_groups']) &gt; 0</attribute>
        </xpath>
        <xpath expr="//tr[@class='o_total']//strong[@t-out]" position="attributes">
            <attribute name="t-options">{'widget': 'float', 'precision': 0}</attribute>
        </xpath>
    </template>

</odoo>
