<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_a5_invoice" model="report.paperformat">
        <field name="name">SKB A5 Invoice</field>
        <field name="format">A5</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">52</field>
        <field name="margin_bottom">32</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">52</field>
        <field name="dpi">90</field>
    </record>

    <!-- Print with/without payments both use A5 -->
    <record id="account.account_invoices" model="ir.actions.report">
        <field name="paperformat_id" ref="skb_account_report.paperformat_a5_invoice"/>
    </record>
    <record id="account.account_invoices_without_payment" model="ir.actions.report">
        <field name="paperformat_id" ref="skb_account_report.paperformat_a5_invoice"/>
    </record>
</odoo>
